# Copy this to .env and fill in real values
# (This file is safe to commit — it contains no secrets)

# ─── GitHub API ───────────────────────────────────────────────────────────────
# Personal Access Token (classic) with public_repo scope
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Your Supabase project URL
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co

# Supabase SERVICE ROLE key (NOT the anon key — needs write access)
# Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx

# ─── Run type ─────────────────────────────────────────────────────────────────
# 'daily' or 'weekly'  (GitHub Actions sets this automatically)
RUN_TYPE=daily
